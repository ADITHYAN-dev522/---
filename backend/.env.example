# SentinelNexus environment configuration
# Copy this file as .env and fill in your values

# ─── VirusTotal (free tier) ───────────────────────────────────────────────────
# Sign up at https://www.virustotal.com/gui/join-community
VT_API_KEY=your_virustotal_api_key_here

# ─── Google Gemini (for AI Copilot fallback) ──────────────────────────────────
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Ollama LLM ───────────────────────────────────────────────────────────────
OLLAMA_API=http://localhost:11434/api/generate
AI_MODEL=qwen2.5:7b-instruct

# ─── Wazuh Manager API ────────────────────────────────────────────────────────
WAZUH_USER=wazuh
WAZUH_PASSWORD=your_wazuh_manager_password_here

# ─── Wazuh Indexer (OpenSearch) ───────────────────────────────────────────────
WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=your_wazuh_indexer_password_here

# ─── Scan targets (comma-separated paths) ────────────────────────────────────
SCAN_DIRS=/home/kali/Music
MALWARE_SCAN_DIRS=/home/kali/Music
