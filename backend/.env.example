# SentinelNexus environment configuration
# Copy this file as .env and fill in your values

# ─── VirusTotal (free tier) ───────────────────────────────────────────────────
# Sign up at https://www.virustotal.com/gui/join-community
# Your profile → API Key → copy and paste here
VT_API_KEY=ea5615c59ab7b1ee0aa77ec7ae30b42b8ca983cdb83e6a967b9bfd1cdb757828

# ─── Ollama LLM ───────────────────────────────────────────────────────────────
# URL of the Ollama instance (default: local)
OLLAMA_API=http://localhost:11434/api/generate

# Model to use — must be pulled first: ollama pull qwen2.5:7b-instruct
AI_MODEL=qwen2.5:7b-instruct
